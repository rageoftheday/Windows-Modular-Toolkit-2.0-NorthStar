  "installer_arguments": [
    {
      "args": "",
      "description": "None - launch normally / show installer UI"
    },
    {
      "args": "/quiet /norestart",
      "description": "Common Microsoft EXE silent install, no reboot"
    },
    {
      "args": "/silent /norestart",
      "description": "Common quiet install, no reboot"
    },
    {
      "args": "/verysilent /norestart",
      "description": "Inno Setup very quiet install, no reboot"
    },
    {
      "args": "/S",
      "description": "NSIS-style silent install; capital S matters"
    },
    {
      "args": "/passive /norestart",
      "description": "Shows progress only, no reboot"
    },
    {
      "args": "/qn /norestart",
      "description": "MSI silent install, no reboot"
    },
    {
      "args": "/qb! /norestart",
      "description": "MSI basic UI, no cancel button, no reboot"
    },
    {
      "args": "/qn /norestart /l*v \"%TEMP%\\install.log\"",
      "description": "MSI silent install with verbose log"
    },
    {
      "args": "/quiet /norestart /log \"%TEMP%\\install.log\"",
      "description": "Common EXE quiet install with log path"
    }
  ],
